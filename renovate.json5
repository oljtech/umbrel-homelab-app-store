{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",

  extends: [
    "config:recommended",
    // Épingle le digest @sha256 en plus du tag pour les images Docker
    "docker:pinDigests",
  ],

  labels: ["dependencies"],
  // Tableau de bord récap dans un issue GitHub
  dependencyDashboard: true,

  // Le manager docker-compose natif gère déjà les images (tag + digest)
  // dans les docker-compose.yml de chaque app.
  // Ces custom managers ajoutent la MAJ du champ `version:` du manifeste
  // Umbrel, qui n'est pas un format de package standard. Un manager par app,
  // scopé sur son dossier, car le depName est en dur.
  customManagers: [
    {
      customType: "regex",
      managerFilePatterns: ["/homelab-homepage/umbrel-app\\.yml$/"],
      // Ne matche que `version: "x.y.z"` (entre guillemets) — donc PAS
      // `manifestVersion: 1` qui est sans guillemets.
      matchStrings: ["version:\\s*\"(?<currentValue>[^\"]+)\""],
      depNameTemplate: "ghcr.io/gethomepage/homepage",
      datasourceTemplate: "docker",
      versioningTemplate: "docker",
      // Le manifeste utilise "1.13.2" alors que le tag de l'image est "v1.13.2".
      // On retire le "v" pour garder le champ sans préfixe.
      extractVersionTemplate: "^v?(?<version>.+)$",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/homelab-picsou-finance/umbrel-app\\.yml$/"],
      matchStrings: ["version:\\s*\"(?<currentValue>[^\"]+)\""],
      depNameTemplate: "ghcr.io/zoeille/picsou-finance",
      datasourceTemplate: "docker",
      versioningTemplate: "docker",
      // Tags picsou sans préfixe "v", mais on garde le strip par cohérence.
      extractVersionTemplate: "^v?(?<version>.+)$",
    },
  ],

  packageRules: [
    // Le digest n'a aucun sens dans le manifeste : pas de pinDigests ici
    // (sinon le custom manager casse — bug connu de Renovate).
    {
      matchManagers: ["custom.regex"],
      pinDigests: false,
    },
    // Une seule PR met à jour le compose ET le manifeste ensemble.
    {
      matchDatasources: ["docker"],
      matchPackageNames: ["ghcr.io/gethomepage/homepage"],
      groupName: "homepage",
    },
    // Idem pour picsou : app + sidecar tr-auth (mêmes tags) + manifeste
    // groupés en une PR.
    {
      matchDatasources: ["docker"],
      matchPackageNames: [
        "ghcr.io/zoeille/picsou-finance",
        "ghcr.io/zoeille/picsou-finance/tr-auth",
      ],
      groupName: "picsou-finance",
    },
    // Postgres : rester en 16-alpine (MAJ majeure = migration manuelle du
    // datadir) ; Renovate ne met à jour que le digest.
    {
      matchDatasources: ["docker"],
      matchPackageNames: ["postgres"],
      matchUpdateTypes: ["major"],
      enabled: false,
    },
  ],
}
